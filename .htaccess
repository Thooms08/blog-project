# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home/flavoryi/blog.flavory.id"
PassengerBaseURI "/"
PassengerNodejs "/home/flavoryi/nodevenv/blog.flavory.id/22/bin/node"
PassengerAppType node
PassengerStartupFile app.js
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

# Prevent directory listing to hide file contents
Options -Indexes

RewriteEngine On

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# === STATIC FILES: Arahkan ke folder public/ ===
# Jika request bukan ke folder public/ dan file ada di public/, forward ke sana
RewriteCond %{REQUEST_URI} !^/public/
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
RewriteRule ^(.+)$ /public/$1 [L,QSA]

# Jika request bukan ke folder public/ dan folder ada di public/, forward ke sana
RewriteCond %{REQUEST_URI} !^/public/
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
RewriteRule ^(.+)$ /public/$1 [L,QSA]

# Protect sensitive files from being accessed
<Files ".env*">
    Order allow,deny
    Deny from all
</Files>
<Files ".git*">
    Order allow,deny
    Deny from all
</Files>
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>
<Files "wp-config.php">
    Order allow,deny
    Deny from all
</Files>

# Security headers to enhance web security
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options DENY
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Block access to common backup and temporary files
<FilesMatch "\.(bak|backup|old|tmp|temp|swp|swo)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent access to .htaccess itself
<Files ".htaccess">
    Order allow,deny
    Deny from all
</Files>

# Limit request methods to GET, POST, HEAD
<LimitExcept GET POST HEAD>
    Deny from all
</LimitExcept>

